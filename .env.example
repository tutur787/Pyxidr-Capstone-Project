# Copy this file to .env and fill in values. Never commit .env.

# Gurobi WLS credentials — obtain from https://license.gurobi.com
GRB_WLSACCESSID=
GRB_WLSSECRET=
GRB_LICENSEID=

# GCP — credentials come from gcloud ADC (run: gcloud auth application-default login)
GCP_PROJECT_ID=your-gcp-project-id
GCS_INPUT_BUCKET=
GCS_OUTPUT_BUCKET=
